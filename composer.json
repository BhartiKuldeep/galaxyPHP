{
  "name": "bhartikuldeep/galaxyphp",
  "description": "GalaxyPHP v2 - a secure, lightweight PHP MVC starter kit with auth, routing, JSON storage, APIs, tests, and CLI tooling.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "Galaxy\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "scripts": {
    "serve": "php galaxy serve",
    "migrate": "php galaxy migrate",
    "seed": "php galaxy seed",
    "test": "php tests/run.php"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  }
}
